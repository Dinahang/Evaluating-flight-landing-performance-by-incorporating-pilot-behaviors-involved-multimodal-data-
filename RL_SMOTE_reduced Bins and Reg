def main():
    files = list_raw_csvs(DATA_FOLDER)
    if not files:
        print(f"No CSV files found in {DATA_FOLDER}") #failure safe_csv file
        return

    records = [process_file(f) for f in files]
    df_all = pd.DataFrame([r for r in records if r is not None])

    if df_all.empty:
        print("No valid landing data found.")
        return

    out_raw = os.path.join(DATA_FOLDER, "processed_landings_raw.csv")
    df_all.to_csv(out_raw, index=False)
    print(f"[INFO] Saved raw engineered features to {out_raw}")

    # Build feature matrix scenario one-hot encoding 
    target_vs = 'vs_td_target'
    target_g = 'g_td_target'
    base_non_features = ['file', 'scenario', target_vs, target_g, 'hard_landing_flag']

    base_feature_cols = [c for c in df_all.columns if c not in base_non_features]
    scen_dummies = pd.get_dummies(df_all['scenario'], prefix='scen')
    X_df = pd.concat([df_all[base_feature_cols], scen_dummies], axis=1)  # one-hot added here
    feature_cols = list(X_df.columns)

    X = X_df.copy()
    y_vs = df_all[target_vs].astype(float).copy()
    y_g  = df_all[target_g].astype(float).copy()
    scen_series = df_all['scenario']

    imputer = SimpleImputer(strategy='median')
    X_filled = imputer.fit_transform(X)

    # Regression_ !! GLOBAL VS MODEL 
    X_train, X_test, y_train_vs, y_test_vs, scen_tr, scen_te = train_test_split(
        X_filled, y_vs, scen_series, test_size=0.2, random_state=42, stratify=scen_series
    )
    model_vs = RandomForestRegressor(n_estimators=300, max_depth=12, random_state=42, n_jobs=-1)
    model_vs.fit(X_train, y_train_vs)
    preds_vs = model_vs.predict(X_test)

    print("\n[GLOBAL VS MODEL]")
    print(f"R^2:  {r2_score(y_test_vs, preds_vs):.4f}")
    print(f"MAE:  {mean_absolute_error(y_test_vs, preds_vs):.2f} fpm")
    print(f"RMSE: {mean_squared_error(y_test_vs, preds_vs, squared=False):.2f} fpm")

    # Regression_ !! GLOBAL G MODEL 
    X_train_g, X_test_g, y_train_g, y_test_g, scen_tr_g, scen_te_g = train_test_split(
        X_filled, y_g, scen_series, test_size=0.2, random_state=42, stratify=scen_series
    )
    model_g = RandomForestRegressor(n_estimators=300, max_depth=12, random_state=42, n_jobs=-1)
    model_g.fit(X_train_g, y_train_g)
    preds_g = model_g.predict(X_test_g)

    print("\n[GLOBAL G MODEL]")
    print(f"R^2:  {r2_score(y_test_g, preds_g):.4f}")
    print(f"MAE:  {mean_absolute_error(y_test_g, preds_g):.4f} (channel units)")
    print(f"RMSE: {mean_squared_error(y_test_g, preds_g, squared=False):.4f} (channel units)")

    #  Anomaly Detection
    iso = IsolationForest(contamination=0.10, random_state=42)
    df_all['anomaly_label'] = iso.fit_predict(X_filled)

    # Permutation Importance (VS only, fast) 
    if DO_PERM_IMPORTANCE:
        try:
            global_permutation_report(
                model_vs,
                X_test,
                y_test_vs,
                feature_cols,
                "Global Permutation Importance (VS)",
                n_repeats=PERM_N_REPEATS
            )
        except Exception as e:
            print(f"[WARN] Permutation importance skipped: {e}")

    #Per-scenario evaluation (NO retraining) 
    scenario_metrics = []
    for scen_name, df_s in df_all.groupby('scenario'):
        if len(df_s) < 5:
            continue
        Xs = X_df.loc[df_s.index]
        Xs_filled = imputer.transform(Xs)
        ys_vs = df_s[target_vs].values
        ys_g  = df_s[target_g].values

        p_vs = model_vs.predict(Xs_filled)
        p_g  = model_g.predict(Xs_filled)

        scen_row = {
            'scenario': scen_name,
            'n': len(df_s),
            'VS_R2': r2_score(ys_vs, p_vs) if len(np.unique(ys_vs)) > 1 else np.nan,
            'VS_MAE_fpm': mean_absolute_error(ys_vs, p_vs),
            'VS_RMSE_fpm': mean_squared_error(ys_vs, p_vs, squared=False),
            'G_R2': r2_score(ys_g, p_g) if len(np.unique(ys_g)) > 1 else np.nan,
            'G_MAE_g': mean_absolute_error(ys_g, p_g),
            'G_RMSE_g': mean_squared_error(ys_g, p_g, squared=False),
        }
        scenario_metrics.append(scen_row)

    if scenario_metrics:
        df_scen = pd.DataFrame(scenario_metrics)
        out_scen = os.path.join(DATA_FOLDER, "scenario_metrics.csv")
        df_scen.to_csv(out_scen, index=False)
        print(f"[INFO] Per-scenario metrics saved to {out_scen}")
        print(df_scen.sort_values('scenario'))

    #  Practical EDA #Visializaiton plott output
    try:
        # Pred vs Actual (Global)
        fig, ax = plt.subplots(1, 2, figsize=(12, 5))
        ax[0].scatter(y_test_vs, preds_vs, alpha=0.6, edgecolor='k')
        lims = [min(y_test_vs.min(), preds_vs.min()), max(y_test_vs.max(), preds_vs.max())]
        ax[0].plot(lims, lims, 'r--')
        ax[0].set_xlim(lims); ax[0].set_ylim(lims)
        ax[0].set_title("VS: Predicted vs Actual")
        ax[0].set_xlabel("Actual VS (fpm)"); ax[0].set_ylabel("Predicted VS (fpm)")

        ax[1].scatter(y_test_g, preds_g, alpha=0.6, edgecolor='k', color='tab:green')
        lims = [min(y_test_g.min(), preds_g.min()), max(y_test_g.max(), preds_g.max())]
        ax[1].plot(lims, lims, 'r--')
        ax[1].set_xlim(lims); ax[1].set_ylim(lims)
        ax[1].set_title("G: Predicted vs Actual")
        ax[1].set_xlabel("Actual G (channel units)"); ax[1].set_ylabel("Predicted G")
        plt.tight_layout(); plt.show()

        # Residual distributions
        err_vs = preds_vs - y_test_vs.values
        err_g  = preds_g - y_test_g.values
        fig, ax = plt.subplots(1, 2, figsize=(12, 5))
        sns.histplot(err_vs, bins=30, kde=True, ax=ax[0], color='tab:blue')
        ax[0].set_title("VS Residuals (Pred - Actual) [fpm]")
        sns.histplot(err_g, bins=30, kde=True, ax=ax[1], color='tab:orange')
        ax[1].set_title("G Residuals (Pred - Actual)")
        plt.tight_layout(); plt.show()

        # Scenario boxplots
        if 'scenario' in df_all.columns:
            fig, ax = plt.subplots(1, 2, figsize=(14, 5))
            sns.boxplot(data=df_all, x='scenario', y='vs_td_target', ax=ax[0])
            ax[0].set_title("VS by Scenario (Touchdown fpm)")
            ax[0].tick_params(axis='x', rotation=30)
            sns.boxplot(data=df_all, x='scenario', y='g_td_target', ax=ax[1], color='lightgreen')
            ax[1].set_title("G by Scenario (Touchdown)")
            ax[1].tick_params(axis='x', rotation=30)
            plt.tight_layout(); plt.show()

        # Key relationships
        def safe_scatter(xname, y, title, color='tab:blue'):
            if xname in df_all.columns:
                plt.figure(figsize=(5.5, 4.5))
                plt.scatter(df_all[xname], df_all[y], alpha=0.5, edgecolor='k', color=color)
                plt.xlabel(xname); plt.ylabel(y); plt.title(title)
                plt.tight_layout(); plt.show()

        safe_scatter('ias_td', 'vs_td_target', 'VS vs IAS at TD')
        safe_scatter('headwind_td', 'vs_td_target', 'VS vs Headwind at TD')
        safe_scatter('bank_td_deg', 'g_td_target', 'G vs |Bank| at TD', color='tab:red')

    except Exception as e:
        print(f"[WARN] EDA plotting skipped due to: {e}")

    #  Optional per-landing explanation (k-NN surrogate only) 
    EXPLAIN_LANDING_FILE = None  # set a filename to explain
    if EXPLAIN_LANDING_FILE is not None:
        mask = df_all['file'].str.lower() == EXPLAIN_LANDING_FILE.lower()
        if not mask.any():
            print(f"[WARN] Landing file '{EXPLAIN_LANDING_FILE}' not found in processed data.")
        else:
            row_idx = mask.idxmax()
            X_all_filled = SimpleImputer(strategy='median').fit_transform(X_df)
            X_all_df = pd.DataFrame(X_all_filled, columns=feature_cols, index=df_all.index)
            explanation = local_surrogate(model_vs, X_all_df, feature_cols, row_idx)
            print(f"Method: {explanation['method']}")
            print(explanation['values'].head(15))

    #  HARD-LANDING CLASSIFIER WITH SMOTE + UNDERSAMPLING 
    if SMOTE_AVAILABLE and USE_SMOTE_CLASSIFIER:
        print("\n[HARD-LANDING CLASSIFIER WITH SMOTE + RANDOM UNDERSAMPLING]")
        y_cls = df_all['hard_landing_flag'].astype(int).values

        # Basic split for inspection
        X_train_c, X_test_c, y_train_c, y_test_c = train_test_split(
            X_df.values, y_cls, test_size=0.2, random_state=42, stratify=y_cls
        )

        clf_pipe = ImbPipeline(steps=[
            ('imputer', SimpleImputer(strategy='median')),
            ('smote', SMOTE(
                sampling_strategy=SMOTE_SAMPLING_STRATEGY,
                random_state=42,
                k_neighbors=3          # small k for small minority counts
            )),
            ('under', RandomUnderSampler(
                sampling_strategy=UNDER_SAMPLING_STRATEGY_CLS,
                random_state=42
            )),
            ('rf', RandomForestClassifier(
                n_estimators=300,
                max_depth=12,
                random_state=42,
                n_jobs=-1
            ))
        ])

        from collections import Counter
        print("Class balance (overall):", Counter(y_cls))
        print("Class balance (train) before SMOTE:", Counter(y_train_c))

        # Fit on train split
        clf_pipe.fit(X_train_c, y_train_c)
        pred_c = clf_pipe.predict(X_test_c)
        try:
            proba_c = clf_pipe.predict_proba(X_test_c)[:, 1]
        except Exception:
            proba_c = None

        print("Confusion matrix (hold-out):\n", confusion_matrix(y_test_c, pred_c))
        print("\nClassification report (hold-out):\n", classification_report(y_test_c, pred_c, digits=3))
        if proba_c is not None:
            try:
                print("ROC-AUC (hold-out): %.3f" % roc_auc_score(y_test_c, proba_c))
            except Exception:
                pass

        #  make NEW: 5-fold CV to get more stable estimate 
        print("\n[5-FOLD CV PERFORMANCE (SMOTE + UNDERSAMPLING)]")
        cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
        f1_scores = cross_val_score(clf_pipe, X_df.values, y_cls, cv=cv, scoring='f1')
        roc_scores = cross_val_score(clf_pipe, X_df.values, y_cls, cv=cv, scoring='roc_auc')

        print("F1 scores (per fold):", np.round(f1_scores, 3))
        print("Mean F1:", f1_scores.mean())
        print("ROC-AUC (per fold):", np.round(roc_scores, 3))
        print("Mean ROC-AUC:", roc_scores.mean())

    elif USE_SMOTE_CLASSIFIER and not SMOTE_AVAILABLE:
        print("[INFO] imbalanced-learn not installed; skipping SMOTE classifier. Run: pip install imbalanced-learn")

    #  SMOTE-FOR-REGRESSION (optional, with undersampling of bins) 
    if SMOTE_AVAILABLE and USE_SMOTE_REGRESSION:
        print("\n[VS REGRESSION WITH RARE-TARGET OVERSAMPLING (SMOTE on bins + optional undersampling)]")
        X_vs_sm, y_vs_sm, imp_vs = smote_regression_resample(
            X_df,
            df_all['vs_td_target'],
            n_bins=SMOTE_BINS,
            smote_strategy=SMOTE_REG_STRATEGY,
            under_strategy=SMOTE_REG_UNDER_STRATEGY
        )
        if X_vs_sm is not None:
            rf_vs_sm = RandomForestRegressor(n_estimators=300, max_depth=12, random_state=42, n_jobs=-1)
            rf_vs_sm.fit(X_vs_sm, y_vs_sm)

            # Evaluate on an untouched split for fairness
            X_train_eval, X_test_eval, y_train_eval, y_test_eval, scen_tr2, scen_te2 = train_test_split(
                X_df, df_all['vs_td_target'].values, df_all['scenario'], test_size=0.2,
                random_state=7, stratify=df_all['scenario']
            )
            X_test_imp = imp_vs.transform(X_test_eval)
            preds_vs_sm = rf_vs_sm.predict(X_test_imp)
            print(f"R^2:  {r2_score(y_test_eval, preds_vs_sm):.4f}")
            print(f"MAE:  {mean_absolute_error(y_test_eval, preds_vs_sm):.2f} fpm")
            print(f"RMSE: {mean_squared_error(y_test_eval, preds_vs_sm, squared=False):.2f} fpm")

        print("\n[G REGRESSION WITH RARE-TARGET OVERSAMPLING (SMOTE on bins + optional undersampling)]")
        X_g_sm, y_g_sm, imp_g = smote_regression_resample(
            X_df,
            df_all['g_td_target'],
            n_bins=SMOTE_BINS,
            smote_strategy=SMOTE_REG_STRATEGY,
            under_strategy=SMOTE_REG_UNDER_STRATEGY
        )
        if X_g_sm is not None:
            rf_g_sm = RandomForestRegressor(n_estimators=300, max_depth=12, random_state=42, n_jobs=-1)
            rf_g_sm.fit(X_g_sm, y_g_sm)

            X_train_eval_g, X_test_eval_g, y_train_eval_g, y_test_eval_g, scen_tr3, scen_te3 = train_test_split(
                X_df, df_all['g_td_target'].values, df_all['scenario'], test_size=0.2,
                random_state=7, stratify=df_all['scenario']
            )
            X_test_imp_g = imp_g.transform(X_test_eval_g)
            preds_g_sm = rf_g_sm.predict(X_test_imp_g)
            print(f"R^2:  {r2_score(y_test_eval_g, preds_g_sm):.4f}")
            print(f"MAE:  {mean_absolute_error(y_test_eval_g, preds_g_sm):.4f} (channel units)")
            print(f"RMSE: {mean_squared_error(y_test_eval_g, preds_g_sm, squared=False):.4f} (channel units)")
    elif USE_SMOTE_REGRESSION and not SMOTE_AVAILABLE:
        print("[INFO] imbalanced-learn not installed; skipping SMOTE-for-regression. Run: pip install imbalanced-learn")

    # out_final!
    out_final = os.path.join(DATA_FOLDER, "processed_landings.csv")
    X_out = X_df.copy()
    X_out['vs_td_target'] = df_all['vs_td_target'].values
    X_out['g_td_target']  = df_all['g_td_target'].values
    X_out['hard_landing_flag'] = df_all['hard_landing_flag'].values
    X_out['scenario'] = df_all['scenario'].values
    X_out['file'] = df_all['file'].values
    X_out.to_csv(out_final, index=False)
    print(f"[INFO] Pipeline Complete. Data saved to {out_final}")

if __name__ == "__main__":
    main()
