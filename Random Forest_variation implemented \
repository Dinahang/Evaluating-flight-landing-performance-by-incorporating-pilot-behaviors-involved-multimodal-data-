#Global: Permutation importance (which features matter most).
#Per‑landing (on request): SHAP explanations or local linear surrogate if SHAP unavailable.

def global_permutation_report(model, X_test, y_test, feat_names, title: str, n_repeats: int = 10):
    """Global permutation importance on the test split + plot."""
    result = permutation_importance(model, X_test, y_test, n_repeats=n_repeats, random_state=42, n_jobs=-1)
    importances = pd.Series(result.importances_mean, index=feat_names).sort_values()
    plt.figure(figsize=(10, 6))
    importances.tail(15).plot(kind='barh')
    plt.title(title)
    plt.tight_layout()
    plt.show()
    return importances

def local_shap_or_surrogate(model, X_all: pd.DataFrame, feat_names: List[str], row_idx: int):
    """
    Try SHAP TreeExplainer for a single row.
    If SHAP unavailable, use a local linear surrogate built on k-NN neighborhood.
    """
    x_row = X_all.iloc[[row_idx]]
    explanation = {}

    #SHAP
    try:
        import shap
        explainer = shap.TreeExplainer(model)
        shap_vals = explainer.shap_values(X_all, check_additivity=False)
        # shap_values can be list for multi-output or class-based; ensure array
        if isinstance(shap_vals, list):
            shap_vals = shap_vals[0]
        row_shap = pd.Series(shap_vals[row_idx], index=feat_names).sort_values(key=np.abs, ascending=False)
        explanation['method'] = 'SHAP'
        explanation['values'] = row_shap

        # Waterfall / bar
        try:
            shap.plots.waterfall(shap.Explanation(values=shap_vals[row_idx],
                                                  base_values=explainer.expected_value,
                                                  data=X_all.iloc[row_idx].values,
                                                  feature_names=feat_names))
            plt.show()
        except Exception:
            # fallback bar plot
            row_shap.head(15).plot(kind='barh', figsize=(8, 6))
            plt.title("Top Local SHAP Attributions")
            plt.tight_layout()
            plt.show()

        return explanation
    except Exception as e:
        # Local linear surrogate using k-NN
        k = min(50, max(10, int(0.2 * len(X_all))))
        nbrs = NearestNeighbors(n_neighbors=k, metric='euclidean')
        nbrs.fit(X_all.values)
        distances, indices = nbrs.kneighbors(x_row.values)
        X_local = X_all.iloc[indices[0]]
        # For regression, we need corresponding target; we will use model predictions as pseudo-target
        y_local = model.predict(X_local.values)
        lin = LinearRegression()
        lin.fit(X_local.values, y_local)
        coefs = pd.Series(lin.coef_, index=feat_names).sort_values(key=np.abs, ascending=False)

        explanation['method'] = 'Local linear surrogate (k-NN)'
        explanation['values'] = coefs

        coefs.head(15).plot(kind='barh', figsize=(8, 6), color='tab:purple')
        plt.title("Top Local Surrogate Coefficients")
        plt.tight_layout()
        plt.show()
        return explanation

