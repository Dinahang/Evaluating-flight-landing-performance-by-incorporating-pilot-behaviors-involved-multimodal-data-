def main():
    files = glob.glob(os.path.join(DATA_FOLDER, "*.csv"))
    if not files:
        print(f"No CSV files found in {DATA_FOLDER}")
        return

    # Process all landings
    records = [process_file(f) for f in files]
    df_all = pd.DataFrame([r for r in records if r is not None])

    if df_all.empty:
        print("No valid landing data found.")
        return

    # Save engineered features
    out_raw = os.path.join(DATA_FOLDER, "processed_landings_raw.csv")
    df_all.to_csv(out_raw, index=False)
    print(f"[INFO] Saved raw engineered features to {out_raw}")

    # Prepare ML data
    target_vs = 'vs_td_target'
    target_g = 'g_td_target'
    non_features = ['file', 'scenario', target_vs, target_g]

    feature_cols = [c for c in df_all.columns if c not in non_features]
    X = df_all[feature_cols].copy()
    y_vs = df_all[target_vs].copy()
    y_g = df_all[target_g].copy()

    # Impute
    imputer = SimpleImputer(strategy='median')
    X_filled = imputer.fit_transform(X)

    
    # GLOBAL MODELS
    
    X_train, X_test, y_train_vs, y_test_vs = train_test_split(X_filled, y_vs, test_size=0.2, random_state=42)
    model_vs = RandomForestRegressor(n_estimators=500, random_state=42, n_jobs=-1)
    model_vs.fit(X_train, y_train_vs)
    preds_vs = model_vs.predict(X_test)

    print("\n[GLOBAL VS MODEL]")
    print(f"R^2:  {r2_score(y_test_vs, preds_vs):.4f}")
    print(f"MAE:  {mean_absolute_error(y_test_vs, preds_vs):.2f} fpm")
    print(f"RMSE: {mean_squared_error(y_test_vs, preds_vs, squared=False):.2f} fpm")

    # G model
    X_train_g, X_test_g, y_train_g, y_test_g = train_test_split(X_filled, y_g, test_size=0.2, random_state=42)
    model_g = RandomForestRegressor(n_estimators=500, random_state=42, n_jobs=-1)
    model_g.fit(X_train_g, y_train_g)
    preds_g = model_g.predict(X_test_g)

    print("\n[GLOBAL G MODEL]")
    print(f"R^2:  {r2_score(y_test_g, preds_g):.4f}")
    print(f"MAE:  {mean_absolute_error(y_test_g, preds_g):.4f} g")
    print(f"RMSE: {mean_squared_error(y_test_g, preds_g, squared=False):.4f} g")

    
    # ANOMALY DETECTION
    
    iso = IsolationForest(contamination=0.10, random_state=42)
    df_all['anomaly_label'] = iso.fit_predict(X_filled)  # -1 anomaly

    
    # GLOBAL EXPLAINABILITY (Permutation)
  
    try:
        global_permutation_report(model_vs, X_test, y_test_vs, feature_cols, "Global Permutation Importance (VS)")
        global_permutation_report(model_g, X_test_g, y_test_g, feature_cols, "Global Permutation Importance (G)")
    except Exception as e:
        print(f"[WARN] Global permutation importance skipped: {e}")

    
    # PER-SCENARIO MODELING / EVALUATION
    
    scenario_metrics = []
    for scen, df_s in df_all.groupby('scenario'):
        if len(df_s) < 12:
            continue  # skip tiny samples to avoid unstable splits
        Xs = df_s[feature_cols]
        ys_vs = df_s[target_vs]
        ys_g = df_s[target_g]

        Xs_filled = imputer.fit_transform(Xs)

        # VS
        Xtr, Xte, ytr, yte = train_test_split(Xs_filled, ys_vs, test_size=0.2, random_state=42)
        m_vs = RandomForestRegressor(n_estimators=400, random_state=42, n_jobs=-1)
        m_vs.fit(Xtr, ytr)
        p_vs = m_vs.predict(Xte)

        # G
        Xtrg, Xteg, ytrg, yteg = train_test_split(Xs_filled, ys_g, test_size=0.2, random_state=42)
        m_g = RandomForestRegressor(n_estimators=400, random_state=42, n_jobs=-1)
        m_g.fit(Xtrg, ytrg)
        p_g = m_g.predict(Xteg)

        scen_row = {
            'scenario': scen,
            'n': len(df_s),
            'VS_R2': r2_score(yte, p_vs),
            'VS_MAE_fpm': mean_absolute_error(yte, p_vs),
            'VS_RMSE_fpm': mean_squared_error(yte, p_vs, squared=False),
            'G_R2': r2_score(yteg, p_g),
            'G_MAE_g': mean_absolute_error(yteg, p_g),
            'G_RMSE_g': mean_squared_error(yteg, p_g, squared=False),
        }
        scenario_metrics.append(scen_row)

        # Quick scenario plots
        try:
            fig, ax = plt.subplots(1, 2, figsize=(12, 5))
            ax[0].scatter(yte, p_vs, alpha=0.7, edgecolor='k')
            ax[0].plot([yte.min(), yte.max()], [yte.min(), yte.max()], 'r--')
            ax[0].set_title(f"{scen} VS: Predicted vs Actual")
            ax[0].set_xlabel("Actual VS (fpm)")
            ax[0].set_ylabel("Predicted VS (fpm)")

            ax[1].scatter(yteg, p_g, alpha=0.7, edgecolor='k', color='tab:green')
            ax[1].plot([yteg.min(), yteg.max()], [yteg.min(), yteg.max()], 'r--')
            ax[1].set_title(f"{scen} G: Predicted vs Actual")
            ax[1].set_xlabel("Actual G")
            ax[1].set_ylabel("Predicted G")

            plt.tight_layout()
            plt.show()
        except Exception as e:
            print(f"[WARN] Scenario plots skipped for {scen}: {e}")

    if scenario_metrics:
        df_scen = pd.DataFrame(scenario_metrics)
        out_scen = os.path.join(DATA_FOLDER, "scenario_metrics.csv")
        df_scen.to_csv(out_scen, index=False)
        print(f"[INFO] Per-scenario metrics saved to {out_scen}")
        print(df_scen.sort_values('scenario'))

    
    # PRACTICAL EDA (heatmap maybe)
    
    try:
        # 1) Prediction vs Actual (Global)
        fig, ax = plt.subplots(1, 2, figsize=(12, 5))
        ax[0].scatter(y_test_vs, preds_vs, alpha=0.6, edgecolor='k')
        lims = [min(y_test_vs.min(), preds_vs.min()), max(y_test_vs.max(), preds_vs.max())]
        ax[0].plot(lims, lims, 'r--'); ax[0].set_xlim(lims); ax[0].set_ylim(lims)
        ax[0].set_title("VS: P redicted vs Actual")
        ax[0].set_xlabel("Actual VS (fpm)"); ax[0].set_ylabel("Predicted VS (fpm)")

        ax[1].scatter(y_test_g, preds_g, alpha=0.6, edgecolor='k', color='tab:green')
        lims = [min(y_test_g.min(), preds_g.min()), max(y_test_g.max(), preds_g.max())]
        ax[1].plot(lims, lims, 'r--'); ax[1].set_xlim(lims); ax[1].set_ylim(lims)
        ax[1].set_title("G: Predicted vs Actual")
        ax[1].set_xlabel("Actual G"); ax[1].set_ylabel("Predicted G")
        plt.tight_layout(); plt.show()

        # 2) Error distributions
        err_vs = preds_vs - y_test_vs.values
        err_g = preds_g - y_test_g.values
        fig, ax = plt.subplots(1, 2, figsize=(12, 5))
        sns.histplot(err_vs, bins=30, kde=True, ax=ax[0], color='tab:blue')
        ax[0].set_title("VS Residuals (Pred - Actual) [fpm]")
        sns.histplot(err_g, bins=30, kde=True, ax=ax[1], color='tab:orange')
        ax[1].set_title("G Residuals (Pred - Actual)")
        plt.tight_layout(); plt.show()

        # 3) Scenario-wise boxplots for targets
        if 'scenario' in df_all.columns:
            fig, ax = plt.subplots(1, 2, figsize=(14, 5))
            sns.boxplot(data=df_all, x='scenario', y='vs_td_target', ax=ax[0])
            ax[0].set_title("VS by Scenario (Touchdown fpm)"); ax[0].tick_params(axis='x', rotation=30)
            sns.boxplot(data=df_all, x='scenario', y='g_td_target', ax=ax[1], color='lightgreen')
            ax[1].set_title("G by Scenario (Touchdown)"); ax[1].tick_params(axis='x', rotation=30)
            plt.tight_layout(); plt.show()

        # 4) Target vs key drivers (scatter plot)
        def safe_scatter(xname, y, title, color='tab:blue'):
            if xname in df_all.columns:
                plt.figure(figsize=(5.5, 4.5))
                plt.scatter(df_all[xname], df_all[y], alpha=0.5, edgecolor='k', color=color)
                plt.xlabel(xname); plt.ylabel(y); plt.title(title)
                plt.tight_layout(); plt.show()
        safe_scatter('ias_td', 'vs_td_target', 'VS vs IAS at TD')
        safe_scatter('headwind_td', 'vs_td_target', 'VS vs Headwind at TD')
        safe_scatter('bank_td_deg', 'g_td_target', 'G vs |Bank| at TD', color='tab:red')

    except Exception as e:
        print(f"[WARN] EDA plotting skipped due to: {e}")

    
    #PER-LANDING EXPLAINABILITY 

    if EXPLAIN_LANDING_FILE is not None:
        # Find the row for that file
        mask = df_all['file'].str.lower() == EXPLAIN_LANDING_FILE.lower()
        if not mask.any():
            print(f"[WARN] Landing file '{EXPLAIN_LANDING_FILE}' not found in processed data.")
        else:
            row_idx = mask.idxmax()  # index of the first True
            # Explain with respect to VS model by default
            print(f"\n[EXPLAIN] Per-landing explainability for: {df_all.loc[row_idx, 'file']}")
            try:
                # Use the same imputer on full X to get matrix
                X_all_filled = SimpleImputer(strategy='median').fit_transform(df_all[feature_cols])
                X_all_df = pd.DataFrame(X_all_filled, columns=feature_cols, index=df_all.index)
                explanation = local_shap_or_surrogate(model_vs, X_all_df, feature_cols, row_idx)
                print(f"Method: {explanation['method']}")
                print(explanation['values'].head(15))
            except Exception as e:
                print(f"[WARN] Per-landing explainability failed: {e}")

    # Save final dataset with anomaly labels
    out_final = os.path.join(DATA_FOLDER, "processed_landings.csv")
    df_all.to_csv(out_final, index=False)
    print(f"[INFO] Pipeline Complete. Data saved to {out_final}")

if __name__ == "__main__":
    main()
